{
  "THE_ARCHITECT.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0r.char": "我可没那么容易被摆布。",
  "THE_ARCHITECT.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0r.next": "继续",
  "THE_ARCHITECT.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1r.ancient": "那就试试看。",
  "THE_ARCHITECT.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-attack": "双方",

  "NEOW.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0r.ancient": "外来的……信使……高塔……欢迎……",
  "NEOW.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0r.next": "继续",
  "NEOW.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1r.ancient": "……攀登……高塔……消灭……建筑师……",
  "NEOW.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1r.next": "回答",
  "NEOW.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2r.char": "我不想伤害任何人！但是或许我可以过去看看情况，有什么要我带的包裹吗？",
  "NEOW.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2r.next": "继续",
  "NEOW.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-3r.ancient": "天真……耀眼……去吧… …带上……祝福^",

  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.ancient": "红色的信使！向你问好！从哪里来？来做什么？",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.next": "解释",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.char": "(安洁莉娜讲述了自己的情况）",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.next": "继续",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.ancient": "其他世界！好厉害！信使工作！很辛苦！感染者？听不太懂！",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.next": "继续",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-3.ancient": "总之欧罗巴斯可以帮你！需要什么！尽管说！尽管说！",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.ancient": "又见面了！红色信使！有没有故事！再讲一些！",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.next": "讲述",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-1r.char": "安洁莉娜讲述了自己某次旅行的见闻。",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-1r.next": "继续",
  "OROBAS.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-2r.ancient": "真有趣！下次再见！这是礼物！",

  "DARV.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.ancient": "欢迎你，美丽的小姐，看你的着装，你不像是本地人吧？",
  "DARV.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.next": "介绍",
  "DARV.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.char": "你好，我是安洁莉娜！是一名信使！",
  "DARV.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.next": "继续",
  "DARV.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.ancient": "充满活力，太棒了……你也是去找建筑师的吗？那从我的收藏中随意挑些吧！",
  "DARV.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.ancient": "欢迎你，美丽的小姐！有什么我能为你做的吗？",

  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.ancient": "你看上去很疲惫，孩子。来，过来休息一下……",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.next": "坐下",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.char": "安洁莉娜礼貌地坐下。",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.next": "继续",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.ancient": "哦，好孩子，你也是去杀死建筑师的吗？来吧，我为你装点一番。",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.next": "回答",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-3.char": "我是一名信使，我不为伤害任何人而来。",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-3.next": "继续",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-4.ancient": "当然，当然。你带上这封信去见建筑师吧，它会明白我的意思的。\n但是在此之前，让我先为你赐福……",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.ancient": "来吧，孩子，让我为你送上礼物……",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.next": "答谢",
  "NONUPEIPE.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-1r.char": "谢谢你，美丽的女士。",

  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.ancient": "信使？不是战士！这个棍子，太无力了！与我一战！！",
  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.next": "挥杖",
  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.char": "（安洁莉娜挥动法杖，周围的实相粒子开始凝聚。）",
  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.next": "继续",
  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.ancient": "法术！棍子也是武器！了不起！再拿一把武器吧！",
  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.ancient": "来吧，展示你的法术！而后在我这里拿上更多武器！",
  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.next": "致谢",
  "TANX.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-1r.char": "谢谢你，英勇的战士。",

  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.ancient": "哦，亲爱的，我之前没见过你，你是谁呀？",
  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.next": "介绍",
  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.char": "我是安洁莉娜，是一名信使，我是来找建筑师了解情况的！",
  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.next": "继续",
  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.ancient": "可爱的孩子，来吃些点心吧？",
  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.next": "享用",
  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-3.char": "真好吃，谢谢你！",
  "TEZCATARA.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.ancient": "你回来了，可爱的好孩子，特兹卡塔拉能为你做些什么呢？",

  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.ancient": "瞧谁来了……哦，一个新面孔。",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-0.next": "问候",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.char": "你好？（安洁莉娜有些害怕）",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-1.next": "继续",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.ancient": "不要怕，我的朋友。只需要签下这份契约，你就能获得难以想象的力量。",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-2.next": "拒绝",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-3.char": "对不起，我对这些不感兴趣，而且作为信使，看起来你的这个契约看起来有很多问题。",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-3.next": "继续",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.0-4.ancient": "……无聊的人。",
  "VAKUU.talk.CRIMSONSCEPTER_ANGELINA_MOD-ANGELINA.1-0r.ancient": "切，是你啊。要找建筑师的话，选一个吧。"
}
